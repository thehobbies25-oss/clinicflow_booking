# ============================================
# ClinicFlow - Environment Configuration
# ============================================
# Copy this file to .env and update values
# ============================================

# Server Configuration
PORT=3000
NODE_ENV=development

# Database Configuration
DATABASE_PATH=./data/clinicflow.db

# Security Configuration
# Change this salt in production!
BCRYPT_SALT_ROUNDS=12
APP_SECRET=change-this-secret-key-in-production-minimum-32-chars

# CORS Configuration (comma-separated origins)
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/clinicflow.log

# Demo Mode (set to false in production)
ENABLE_DEMO_RESET=true
